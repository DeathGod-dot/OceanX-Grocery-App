<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/brand_dark"
    android:padding="@dimen/spacing_lg"
    android:gravity="center_vertical">

    <!-- Back arrow -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/on_primary"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:contentDescription="Back"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verify OTP"
        android:textSize="@dimen/text_2xl"
        android:textStyle="bold"
        android:textColor="@color/on_primary"
        android:layout_marginBottom="@dimen/spacing_xs"/>

    <TextView
        android:id="@+id/tvSentTo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OTP sent to +91 XXXXXXXXXX"
        android:textSize="@dimen/text_md"
        android:textColor="#80FFFFFF"
        android:layout_marginBottom="@dimen/spacing_xl"/>

    <!-- OTP Boxes -->
    <LinearLayout
        android:id="@+id/layoutOtpBoxes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_lg">

        <EditText
            android:id="@+id/etOtp1"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="numberDecimal"
            android:maxLength="1"
            android:textSize="@dimen/text_xl"
            android:textColor="@color/on_primary"
            android:textStyle="bold"
            android:cursorVisible="false"/>

        <EditText
            android:id="@+id/etOtp2"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="numberDecimal"
            android:maxLength="1"
            android:textSize="@dimen/text_xl"
            android:textColor="@color/on_primary"
            android:textStyle="bold"
            android:cursorVisible="false"/>

        <EditText
            android:id="@+id/etOtp3"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="numberDecimal"
            android:maxLength="1"
            android:textSize="@dimen/text_xl"
            android:textColor="@color/on_primary"
            android:textStyle="bold"
            android:cursorVisible="false"/>

        <EditText
            android:id="@+id/etOtp4"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="numberDecimal"
            android:maxLength="1"
            android:textSize="@dimen/text_xl"
            android:textColor="@color/on_primary"
            android:textStyle="bold"
            android:cursorVisible="false"/>

    </LinearLayout>

    <!-- Verify Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerify"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:text="@string/verify_otp"
        android:textColor="@color/brand_dark"
        android:textStyle="bold"
        android:textSize="@dimen/text_lg"
        app:backgroundTint="@color/brand_yellow"
        app:cornerRadius="@dimen/btn_radius"
        android:layout_marginBottom="@dimen/spacing_md"/>

    <!-- Countdown + Resend -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#80FFFFFF"
            android:textSize="@dimen/text_md"
            android:layout_marginEnd="@dimen/spacing_xs"/>

        <TextView
            android:id="@+id/tvResend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/resend_otp"
            android:textColor="@color/brand_yellow"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"
            android:enabled="false"
            android:alpha="0.5"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/otp_hint"
        android:textColor="#60FFFFFF"
        android:textSize="@dimen/text_sm"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_xl"/>

</LinearLayout>
