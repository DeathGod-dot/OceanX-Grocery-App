<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/surface"
    android:padding="@dimen/spacing_lg">

    <!-- Success Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSuccess"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/card_radius"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/spacing_xl">

            <!-- Animated checkmark -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅"
                android:textSize="72sp"
                android:layout_marginBottom="@dimen/spacing_md"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/order_success_title"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                android:textColor="@color/accent_green"
                android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_lg"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="@dimen/spacing_md"/>

            <!-- Order ID Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_sm">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/order_id_label"
                    android:textSize="@dimen/text_md"
                    android:textColor="@color/on_surface_secondary"/>
                <TextView
                    android:id="@+id/tvOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_md"
                    android:textStyle="bold"
                    android:textColor="@color/primary"/>
            </LinearLayout>

            <!-- Delivery Time Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_lg">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/estimated_delivery_label"
                    android:textSize="@dimen/text_md"
                    android:textColor="@color/on_surface_secondary"/>
                <TextView
                    android:id="@+id/tvEstimatedTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_md"
                    android:textStyle="bold"
                    android:textColor="@color/accent_green"/>
            </LinearLayout>

            <!-- Continue Shopping -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueShopping"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:text="@string/continue_shopping"
                android:textColor="@color/brand_dark"
                android:textStyle="bold"
                app:backgroundTint="@color/brand_yellow"
                app:cornerRadius="@dimen/btn_radius"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
