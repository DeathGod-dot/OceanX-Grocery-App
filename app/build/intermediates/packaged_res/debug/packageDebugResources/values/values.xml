    <style name="Theme.OceanX" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:statusBarColor">@color/brand_dark</item>
        <item name="android:windowLightStatusBar" ns1:targetApi="23">false</item>

        
        <item name="materialCardViewStyle">@style/Widget.OceanX.CardView</item>

        
        <item name="materialButtonStyle">@style/Widget.OceanX.Button</item>

        
        <item name="textInputStyle">@style/Widget.OceanX.TextInputLayout</item>
    </style>
    <style name="Theme.OceanX.Auth" parent="Theme.OceanX">
        <item name="android:windowBackground">@color/brand_dark</item>
    </style>
    <style name="Widget.OceanX.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/btn_radius</item>
        <item name="backgroundTint">@color/brand_yellow</item>
        <item name="android:textColor">@color/brand_dark</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Widget.OceanX.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>
    <style name="Widget.OceanX.OtpBox" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary</item>
    </style>
    <style name="Widget.OceanX.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_radius</item>
    </style>
    <style name="Widget.OceanX.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/surface</item>
        <item name="titleTextColor">@color/on_surface</item>
    </style>
