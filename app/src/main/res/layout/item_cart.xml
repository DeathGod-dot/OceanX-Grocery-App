<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_sm"
    android:layout_marginVertical="@dimen/spacing_xs"
    app:cardCornerRadius="@dimen/product_card_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_sm"
        android:gravity="center_vertical">

        <!-- Image -->
        <ImageView
            android:id="@+id/ivCartItemImage"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:contentDescription="Cart item image"/>

        <!-- Name + Unit + Price -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvCartItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvCartItemUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/on_surface_secondary"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvCartItemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                android:textColor="@color/accent_green"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Counter + Remove -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Qty counter -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_counter">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCartDecrease"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="32dp"
                    android:layout_height="36dp"
                    android:text="−"
                    android:textSize="@dimen/text_lg"
                    android:textColor="@color/accent_green"
                    android:textStyle="bold"
                    android:padding="0dp"/>

                <TextView
                    android:id="@+id/tvCartItemQty"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textSize="@dimen/text_md"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCartIncrease"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="32dp"
                    android:layout_height="36dp"
                    android:text="+"
                    android:textSize="@dimen/text_lg"
                    android:textColor="@color/accent_green"
                    android:textStyle="bold"
                    android:padding="0dp"/>
            </LinearLayout>

            <!-- Remove -->
            <ImageButton
                android:id="@+id/btnRemoveItem"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_delete"
                android:tint="@color/accent_red"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Remove item"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
